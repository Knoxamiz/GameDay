rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isParent() {
      return signedIn() && request.auth.token.role == "parent";
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == "admin";
    }

    function liveParentId() {
      return "parent-" + request.auth.uid;
    }

    function adminOrganizations() {
      return request.auth.token.organizationIds;
    }

    function adminHasOrg(orgId) {
      return isAdmin()
        && adminOrganizations() is list
        && adminOrganizations().hasAny([orgId]);
    }

    function adminHasAnyOrg(orgIds) {
      return isAdmin()
        && adminOrganizations() is list
        && orgIds is list
        && adminOrganizations().hasAny(orgIds);
    }

    function parentOwnsData(data) {
      return isParent()
        && (
          data.ownerUid == request.auth.uid
          || data.parentUid == request.auth.uid
          || data.parentId == liveParentId()
        );
    }

    match /parents/{parentDocId} {
      allow read, update: if isParent()
        && (
          parentDocId == liveParentId()
          || resource.data.ownerUid == request.auth.uid
          || resource.data.parentUid == request.auth.uid
        );
      allow create: if isParent()
        && parentDocId == liveParentId()
        && request.resource.data.parentId == liveParentId()
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;

      allow read, update: if adminHasAnyOrg(resource.data.organizationIds);
    }

    match /athletes/{athleteId} {
      allow read: if parentOwnsData(resource.data)
        || adminHasOrg(resource.data.organizationId);

      allow create, update: if parentOwnsData(request.resource.data)
        || adminHasOrg(request.resource.data.organizationId);

      allow delete: if false;
    }

    match /registrations/{registrationId} {
      allow read: if parentOwnsData(resource.data)
        || adminHasOrg(resource.data.organizationId);

      allow create: if parentOwnsData(request.resource.data)
        || adminHasOrg(request.resource.data.organizationId);

      allow update: if parentOwnsData(resource.data)
        || adminHasOrg(resource.data.organizationId);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
